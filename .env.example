# Convex — deployment URL (used by both frontend and Python backend)
# Found in your Convex dashboard at https://dashboard.convex.dev
VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_URL=https://your-deployment.convex.cloud

# Convex — deploy key for Python backend mutations
# Found in Convex Dashboard → your project → Settings → Deploy Key
CONVEX_DEPLOY_KEY=prod:your-deployment|your-deploy-key-here

# OpenAI — required for paper summarization and section scoring
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
